# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
dist-electron/
out/
.vite/

# Keep build directory for icons
!build/

# Environment variables - NEVER commit these
.env
.env.local
.env.production
.env.*.local

# Only keep .env.production.example as a template
!.env.production.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Logs
logs/
*.log

# Certificates and signing keys (NEVER commit these)
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# macOS specific
.AppleDouble
.LSOverride
Icon
._*

# Temporary files
*.tmp
*.temp
.cache/
serverGames/

# Test coverage
coverage/
.nyc_output/

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Electron specific
*.asar

# Compressed archives
*.rar
*.zip
*.7z

