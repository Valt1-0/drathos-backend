API_PORT="5001"

# URI is built from MONGO_ROOT_USERNAME/PASSWORD below
# Do not change if using the provided docker-compose
MONGODB_URI="mongodb://admin:CHANGE_ME@mongodb:27017/drathos?authSource=admin"
MONGO_ROOT_USERNAME="admin"
MONGO_ROOT_PASSWORD="CHANGE_ME_strong_password"

# Generate with: openssl rand -base64 64
JWT_TOKEN="CHANGE_ME_long_random_secret"

GAME_FILES_DIR="/usr/src/app/serverData/serverGames"
MOD_FILES_DIR="/usr/src/app/serverData/serverMods"

TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

NODE_ENV="production"

# Allowed origins (e.g. https://drathos.home.arpa)
CORS_ALLOWED_ORIGINS="https://your-domain.com"
CORS_STRICT_MODE="true"
